# DemandIQ Backend - Environment Template
# Copy this file to .env and fill in your values.

# MongoDB Atlas connection string
# Example:
# mongodb+srv://username:password@cluster0.abcde.mongodb.net/demandiq?retryWrites=true&w=majority
DATABASE_URL=

# MongoDB database name inside your Atlas cluster
DATABASE_NAME=demandiq

# App environment
ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Model metadata
MODEL_VERSION=1.0.0
